#!/usr/bin/env bash

download-magento

if [ -n $MAGENTO_INSTALL_SAMPLE_DATA ]; then
    download-sampledata
fi

set-permissions
install-magento

if [ -n $REDIS_ENABLED ]; then
    enable-redis
fi

if [ -n $GRUNT_ENABLED ]; then
    init-grunt
fi

su www-data <<EOSU

    cd $MAGEDIR

    bin/magento setup:upgrade
    if [ -n $MAGENTO_DEPLOY_MODE ]; then
        bin/magento deploy:mode:set $MAGENTO_DEPLOY_MODE
    fi
    bin/magento cache:flush
EOSU
