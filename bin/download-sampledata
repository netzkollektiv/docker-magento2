#!/usr/bin/env bash

su www-data <<EOSU

    echo "Downloading Sample Data"
    cd /tmp
    wget --show-progress https://codeload.github.com/magento/magento2-sample-data/tar.gz/${MAGENTO_VERSION} -O sample-data.tar.gz

    tar -xf sample-data.tar.gz

    cp -r magento2-sample-data-*/* $MAGEDIR/

    rm -f sample-data.tar.gz

EOSU
